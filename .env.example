# Flask Configuration
SECRET_KEY=some-long-random-string
JWT_SECRET_KEY=your-jwt-secret-key

# Database Configuration (Neon PostgreSQL example)
# Replace with your actual Neon connection string
DATABASE_URL=postgresql://username:password@host/database?sslmode=require&channel_binding=require

# Or use SQLite for development (leave DATABASE_URL commented out)
# DATABASE_URL=sqlite:///app.db

# Optional: Flask Environment
FLASK_ENV=development
FLASK_DEBUG=True
